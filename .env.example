# ============================================
# Mini HRIS Environment Configuration
# ============================================
# Copy this file to .env and update values
# DO NOT commit .env to git!

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection details
DB_HOST=localhost
DB_PORT=5433
DB_NAME=mini_hris
DB_USER=postgres
DB_PASSWORD=Rja021005

# ============================================
# AUTHENTICATION
# ============================================
# JWT Secret - MUST be changed in production!
# Use a random string: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================
# ATTENDANCE CONFIGURATION
# ============================================
# Office IP Range(s) - comma separated
# Examples:
#   127.0.0.1/32 (localhost only)
#   192.168.1.0/24 (192.168.1.0 - 192.168.1.255)
#   10.0.0.0/8 (entire 10.x.x.x network)
OFFICE_IP_RANGE=127.0.0.1/32

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# Required for password reset emails
# Uncomment and configure to enable

# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password
# EMAIL_FROM=noreply@mini-hris.local
# EMAIL_FROM_NAME=Mini HRIS System

# ============================================
# LOGGING & MONITORING (Optional)
# ============================================
# LOG_LEVEL=info
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456